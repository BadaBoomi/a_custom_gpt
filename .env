# Beispiel für Tool-Konfiguration
TOOLS=web_search
# Mehrere Tools können durch Kommas getrennt werden, z.B.:
# TOOLS=web_search,calculator,weather

# Logging der Modell-Payload aktivieren (true/false)
LOG_MODEL_PAYLOAD=false

# Logging-Level für Debug-Ausgaben (DEBUG/INFO/WARN/ERROR)
LOG_LEVEL=ERROR
